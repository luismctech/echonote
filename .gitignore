# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
target/
**/*.rs.bk
Cargo.lock.bak
*.pdb

# -----------------------------------------------------------------------------
# Node / pnpm / Vite / Tauri
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
.vite/
.turbo/
.pnpm-store/
.npm/
*.local

# TypeScript build artifacts (composite project caches and emitted JS/D.TS)
*.tsbuildinfo
vite.config.js
vite.config.d.ts
tailwind.config.js
tailwind.config.d.ts
postcss.config.d.ts

# Tauri build outputs
src-tauri/target/
src-tauri/gen/

# -----------------------------------------------------------------------------
# ML models and heavy binaries (distributed separately, see scripts/download-models.sh)
# -----------------------------------------------------------------------------
models/
*.gguf
*.bin
*.onnx
*.safetensors
*.ggml
!models/.gitkeep

# -----------------------------------------------------------------------------
# User data / local runtime artifacts
# -----------------------------------------------------------------------------
audio-cache/
*.wav
*.mp3
*.m4a
*.flac
*.ogg
!tests/fixtures/audio/**/*.wav
!tests/fixtures/audio/**/*.flac
echo.db
echo.db-wal
echo.db-shm
echo.db.backup
logs/
*.log

# -----------------------------------------------------------------------------
# Secrets / local config
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
config.toml
!config.example.toml
# Cargo workspace config is checked in (rpath setup for the Swift
# runtime needed by screencapturekit on macOS).
!.cargo/config.toml

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
.nvim/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Testing / coverage
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
tarpaulin-report.html
cobertura.xml

# -----------------------------------------------------------------------------
# Cursor / local agent artifacts (keep skills, ignore session state)
# -----------------------------------------------------------------------------
.cursor/projects/

# -----------------------------------------------------------------------------
# Runtime data (created by `pnpm tauri dev` / `echo-proto stream`)
# -----------------------------------------------------------------------------
echonote.db
echonote.db-shm
echonote.db-wal

# -----------------------------------------------------------------------------
# Bench fixtures: WAVs are regenerated locally via scripts/build-fixtures.sh
# (transcripts under fixtures/transcripts/ ARE checked in).
# -----------------------------------------------------------------------------
fixtures/audio/

# -----------------------------------------------------------------------------
# Bench reports
